<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="./style.css">
  <title>Members Only</title>
</head>

<body>
  <%- include("navbar", locals.user) %>
  <%if(locals.posts) {%>
  <div class="posts-container">
    <% posts.forEach((post) => { %>
    <div class="post-card">
      <div class="user-info">
        <p><%= post.fullname%></p>
        <p>@<%= post.username%></p>
      </div>
      <div class="post-content">
        <h3><%= post.title %></h3>
        <p><%= post.content %></p>
      </div>
    </div>
    <%}); %>
  </div>
  <%}%>
</body>

</html>