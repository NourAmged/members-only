<nav class="nav">
  <h1 style="cursor: pointer;" onclick="window.location.href='/'">Members Only</h1>
  <%if(locals.user){ %>
  <div class="user-menu" onclick="document.querySelector('.drop-menu').style.display = document.querySelector('.drop-menu').style.display == 'none' ? 'flex' : 'none'">
    <h2><%= user.username%></h2>
    <img src="./down-arrow.svg" width="22px" height="22px">
    <ul class="drop-menu">
      <li><button>New post</button></li>
      <li><button>All users</button></li>
      <li><button>Logout</button></li>
    </ul>
  </div>
  <%} else{%>
  <div class="signin-container">
    <button class="login-btn" onclick="window.location.href='/login'">Login</button>
    <button class="register-btn" onclick="window.location.href='/register'">Register</button>
    <%}%>
  </div>
</nav>